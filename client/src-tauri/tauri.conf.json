{
  "productName": "Starling",
  "version":     "0.1.0",
  "identifier":  "app.mwt.client",
  "build": {
    "frontendDist":        "../dist",
    "devUrl":              "http://localhost:5173",
    "beforeDevCommand":    "npm run dev",
    "beforeBuildCommand":  "npm run build"
  },
  "app": {
    "windows": [
      {
        "title":     "Starling",
        "width":     1100,
        "height":    720,
        "minWidth":  800,
        "minHeight": 520,
        "decorations": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active":  true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "16.0"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        { "schemes": ["mwt"] }
      ],
      "desktop": {
        "schemes": ["mwt"]
      }
    }
  }
}
