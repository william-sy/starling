# Same Postgres as the tax portal — mwt tables live in a separate mwt_* prefix
DATABASE_URL=postgres://user:pass@localhost:5432/portal

# Same JWT secret as the tax portal — one login covers both
JWT_SECRET=change-me

PORT=3002

# MultiSafepay
MULTISAFEPAY_WEBHOOK_SECRET=your-webhook-hmac-secret
# API key for outbound calls (refunds etc) — find in MSP dashboard → API keys
MULTISAFEPAY_API_KEY=your-msp-api-key
# 'test' uses testapi.multisafepay.com, 'live' uses api.multisafepay.com
MULTISAFEPAY_ENV=test

# Brevo SMTP (EU-native transactional email)
# Create account at brevo.com → SMTP & API → SMTP tab
BREVO_SMTP_LOGIN=your-brevo-login@example.com
BREVO_SMTP_KEY=your-brevo-smtp-key

EMAIL_FROM=billing@mwt.app

# CORS — lock to your admin domain in production
ADMIN_ALLOWED_ORIGIN=https://admin.mwt.app

LOG_LEVEL=info
