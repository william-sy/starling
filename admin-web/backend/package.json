{
  "name": "mwt-admin-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "migrate": "docker compose -f ../docker-compose.yml run --rm flyway",
    "migrate:info": "docker compose -f ../docker-compose.yml run --rm flyway info",
    "migrate:repair": "docker compose -f ../docker-compose.yml run --rm flyway repair"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.5",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.11.13",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3"
  }
}
